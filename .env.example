# ==========================================
# Deep-Guardian 환경 변수 설정 예시
# 이 파일을 복사하여 .env 파일을 생성하세요:
#   cp .env.example .env
# ==========================================

# Gemini API Key (AI 요약 기능에 필요)
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ngrok Auth Token (외부 터널링에 필요)
# 발급: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Kakao Map API Key (지도 기능에 필요)
# 발급: https://developers.kakao.com/
KAKAO_MAP_APP_KEY=your_kakao_map_app_key_here
